{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore${scope}: release claude-sessions-npm-beta ${version}",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "claude-sessions-npm-beta",
      "components": ["core", "ui", "web", "mcp"]
    }
  ],
  "packages": {
    "packages/core": {
      "component": "core",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning-strategy": "prerelease"
    },
    "packages/ui": {
      "component": "ui",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning-strategy": "prerelease"
    },
    "packages/web": {
      "component": "web",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning-strategy": "prerelease"
    },
    "packages/mcp": {
      "component": "mcp",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning-strategy": "prerelease"
    }
  }
}
