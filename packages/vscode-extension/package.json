{
  "name": "claude-sessions",
  "displayName": "Claude Code Sessions",
  "description": "Manage Claude Code sessions from VS Code sidebar",
  "version": "0.4.7",
  "publisher": "es6kr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/es6kr/claude-code-sessions",
    "directory": "packages/vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "session",
    "ai"
  ],
  "icon": "resources/marketplace.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-sessions",
          "title": "Claude Sessions",
          "icon": "resources/activity-bar.svg"
        }
      ]
    },
    "views": {
      "claude-sessions": [
        {
          "id": "claudeSessions",
          "name": "Claude Sessions",
          "icon": "resources/activity-bar.svg",
          "canSelectMany": true
        }
      ]
    },
    "commands": [
      {
        "command": "claudeSessions.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeSessions.openSession",
        "title": "Open Session"
      },
      {
        "command": "claudeSessions.renameSession",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "claudeSessions.deleteSession",
        "title": "Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "claudeSessions.openWebUI",
        "title": "Open Web UI",
        "icon": "$(globe)"
      },
      {
        "command": "claudeSessions.cleanup",
        "title": "Cleanup Empty Sessions",
        "icon": "$(clear-all)"
      },
      {
        "command": "claudeSessions.openProjectFolder",
        "title": "Open Project Folder",
        "icon": "$(code)"
      },
      {
        "command": "claudeSessions.openSessionsFolder",
        "title": "Open Sessions Folder",
        "icon": "$(history)"
      },
      {
        "command": "claudeSessions.revealInFinder",
        "title": "Reveal in Finder"
      },
      {
        "command": "claudeSessions.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "claudeSessions.moveSession",
        "title": "Move to Project...",
        "icon": "$(move)"
      },
      {
        "command": "claudeSessions.resumeSession",
        "title": "Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "claudeSessions.openTerminalHere",
        "title": "Open Terminal Here",
        "icon": "$(terminal)"
      },
      {
        "command": "claudeSessions.startClaudeInFolder",
        "title": "Start Claude in Folder",
        "icon": "$(play-circle)"
      },
      {
        "command": "claudeSessions.startClaudeYolo",
        "title": "Start Claude (YOLO)",
        "icon": "$(zap)"
      },
      {
        "command": "claudeSessions.resumeSessionYolo",
        "title": "Resume Session (YOLO)",
        "icon": "$(run-all)"
      },
      {
        "command": "claudeSessions.sortBy",
        "title": "Sort Sessions",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "claudeSessions.toggleGroupByDate",
        "title": "Toggle Group by Date",
        "icon": "$(calendar)"
      },
      {
        "command": "claudeSessions.filterSessions",
        "title": "Filter Sessions",
        "icon": "$(search)"
      },
      {
        "command": "claudeSessions.clearFilter",
        "title": "Clear Filter",
        "icon": "$(close)"
      },
      {
        "command": "claudeSessions.restartExtensionHost",
        "title": "Restart Extension Host",
        "icon": "$(debug-restart)"
      },
      {
        "command": "claudeSessions.restartWebServer",
        "title": "Restart Web Server",
        "category": "Claude Sessions"
      }
    ],
    "keybindings": [
      {
        "command": "claudeSessions.filterSessions",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "focusedView == claudeSessions"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeSessions.clearFilter",
          "when": "view == claudeSessions && claudeSessions.filterActive",
          "group": "navigation@0"
        },
        {
          "command": "claudeSessions.filterSessions",
          "when": "view == claudeSessions",
          "group": "navigation@1"
        },
        {
          "command": "claudeSessions.sortBy",
          "when": "view == claudeSessions",
          "group": "navigation@2"
        },
        {
          "command": "claudeSessions.toggleGroupByDate",
          "when": "view == claudeSessions",
          "group": "navigation@3"
        },
        {
          "command": "claudeSessions.cleanup",
          "when": "view == claudeSessions",
          "group": "navigation@4"
        },
        {
          "command": "claudeSessions.openWebUI",
          "when": "view == claudeSessions",
          "group": "navigation@5"
        },
        {
          "command": "claudeSessions.refresh",
          "when": "view == claudeSessions",
          "group": "navigation@6"
        },
        {
          "command": "claudeSessions.restartExtensionHost",
          "when": "view == claudeSessions",
          "group": "navigation@7"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeSessions.resumeSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "inline@0"
        },
        {
          "command": "claudeSessions.renameSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "claudeSessions.deleteSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "inline@2"
        },
        {
          "command": "claudeSessions.resumeSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "0_open"
        },
        {
          "command": "claudeSessions.openSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "0_open"
        },
        {
          "command": "claudeSessions.resumeSessionYolo",
          "when": "view == claudeSessions && viewItem == session",
          "group": "0_open"
        },
        {
          "command": "claudeSessions.renameSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "1_file"
        },
        {
          "command": "claudeSessions.moveSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "1_file"
        },
        {
          "command": "claudeSessions.deleteSession",
          "when": "view == claudeSessions && viewItem == session",
          "group": "1_file"
        },
        {
          "command": "claudeSessions.revealInFinder",
          "when": "view == claudeSessions && viewItem == session",
          "group": "1_file"
        },
        {
          "command": "claudeSessions.copyPath",
          "when": "view == claudeSessions && viewItem == session",
          "group": "1_file"
        },
        {
          "command": "claudeSessions.openProjectFolder",
          "when": "view == claudeSessions && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "claudeSessions.openSessionsFolder",
          "when": "view == claudeSessions && viewItem == project",
          "group": "inline@2"
        },
        {
          "command": "claudeSessions.openProjectFolder",
          "when": "view == claudeSessions && viewItem == project",
          "group": "1_open"
        },
        {
          "command": "claudeSessions.openSessionsFolder",
          "when": "view == claudeSessions && viewItem == project",
          "group": "1_open"
        },
        {
          "command": "claudeSessions.openTerminalHere",
          "when": "view == claudeSessions && viewItem == project",
          "group": "1_open"
        },
        {
          "command": "claudeSessions.startClaudeInFolder",
          "when": "view == claudeSessions && viewItem == project",
          "group": "2_claude"
        },
        {
          "command": "claudeSessions.startClaudeYolo",
          "when": "view == claudeSessions && viewItem == project",
          "group": "2_claude"
        }
      ]
    },
    "configuration": {
      "title": "Claude Code Sessions",
      "properties": {
        "claudeSessions.port": {
          "type": "number",
          "default": 5174,
          "description": "Port for the web server when viewing sessions"
        },
        "claudeSessions.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the web server when opening a session"
        },
        "claudeSessions.openInEditor": {
          "type": "boolean",
          "default": true,
          "description": "Open sessions in VS Code Simple Browser (true) or external browser (false)"
        },
        "claudeSessions.titleDisplayMode": {
          "type": "string",
          "enum": [
            "message",
            "datetime"
          ],
          "default": "message",
          "enumDescriptions": [
            "Show first user message as session title",
            "Show relative date/time (e.g. '3h ago', 'yesterday') as session title"
          ],
          "description": "How to display session titles when no custom title or summary is set"
        },
        "claudeSessions.excludeProjectPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Patterns to exclude from project list (e.g., 'es6.kr' to hide personal projects)"
        },
        "claudeSessions.packageTag": {
          "type": "string",
          "enum": [
            "",
            "latest",
            "beta"
          ],
          "default": "",
          "enumDescriptions": [
            "No tag — uses npx default resolution (may use cached version)",
            "Always fetch the latest published version",
            "Use the beta channel"
          ],
          "description": "npm dist-tag for @claude-sessions/web package. Empty string uses npx default behavior."
        },
        "claudeSessions.useBetaVersion": {
          "type": "boolean",
          "default": false,
          "description": "Use beta version of @claude-sessions/web package instead of latest",
          "deprecationMessage": "Use 'claudeSessions.packageTag' instead. Set it to 'beta' for the same behavior."
        },
        "claudeSessions.cliFlags": {
          "type": "string",
          "default": "",
          "description": "Additional CLI flags appended to the claude command when resuming sessions (e.g., '--dangerously-skip-permissions')"
        },
        "claudeSessions.defaultTerminalMode": {
          "type": "string",
          "enum": [
            "ask",
            "external",
            "internal"
          ],
          "default": "ask",
          "description": "Default terminal mode when resuming sessions: 'ask' shows a picker, 'internal' uses the integrated terminal, 'external' uses the system terminal"
        },
        "claudeSessions.webServerPath": {
          "type": "string",
          "default": "",
          "description": "Path to a local @claude-sessions/web CLI script (e.g., '/path/to/packages/web/dist/cli.js'). When set, uses this instead of npx."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm build",
    "build": "tsup",
    "dev": "tsup --watch",
    "package": "vsce package --no-dependencies",
    "lint": "eslint src",
    "test": "tsc -p tsconfig.test.json && node ./out/test/runTest.js"
  },
  "dependencies": {
    "@claude-sessions/core": "workspace:^",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
